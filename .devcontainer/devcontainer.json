{
  "name": "Claude Code Sandbox (DevContainer)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "claude-sandbox",
  "workspaceFolder": "/home/claude/project",
  "remoteUser": "claude",
  "remoteEnv": {
    "HOME": "/home/claude"
  },
  "postStartCommand": "/bin/bash /home/claude/project/.devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "rust-lang.rust-analyzer",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
